<header class="cf-header">
    <div class="cf-header-left cf-header-slot @(IsHeaderPosition(LogoPosition.TopLeft) ? "cf-has-logo" : string.Empty)">
        @if (IsHeaderPosition(LogoPosition.TopLeft))
        {
            <CfLogo Logo="Logo" />
        }
        else
        {
            <div class="cf-header-titles">
                <h1 class="cf-title">@Title</h1>
                @if (!string.IsNullOrEmpty(Subtitle))
                {
                    <p class="cf-subtitle">@Subtitle</p>
                }
            </div>
        }
    </div>

    <div class="cf-header-center cf-header-slot">
        @if (IsHeaderPosition(LogoPosition.TopCenter))
        {
            <CfLogo Logo="Logo" />
        }
    </div>

    <div class="cf-header-right cf-header-slot">
        @if (IsHeaderPosition(LogoPosition.TopRight))
        {
            <CfLogo Logo="Logo" />
        }
        @foreach (ConfigForgeHeaderAction action in HeaderActions)
        {
            @if (!string.IsNullOrEmpty(action.IconSvg))
            {
                <a class="cf-header-icon"
                   href="@action.Url"
                   title="@action.Label"
                   aria-label="@action.Label"
                   target="@(action.OpenInNewTab ? "_blank" : null)"
                   rel="@(action.OpenInNewTab ? "noopener noreferrer" : null)">
                    @((MarkupString)action.IconSvg)
                </a>
            }
            else
            {
                <a class="cf-button cf-button-@action.Variant"
                   href="@action.Url"
                   target="@(action.OpenInNewTab ? "_blank" : null)"
                   rel="@(action.OpenInNewTab ? "noopener noreferrer" : null)">
                    @action.Label
                </a>
            }
        }
        @if (ShowCodePanel)
        {
            <button type="button" class="cf-button cf-button-secondary" @onclick="OnToggleCodePanel">
                @(CodePanelOpen ? "Hide code" : "View code")
            </button>
        }
        @if (Mode == ConfigForgeMode.Open && ShowGenerateButton)
        {
            <button type="button" class="cf-button cf-button-primary" @onclick="OnGenerate">
                Generate document…
            </button>
        }
    </div>
</header>

@code {
    /// <summary>The schema title shown in the header.</summary>
    [Parameter]
    public string Title { get; set; } = string.Empty;

    /// <summary>An optional subtitle, e.g. the schema version.</summary>
    [Parameter]
    public string? Subtitle { get; set; }

    /// <summary>An optional logo; only header-positioned logos render here.</summary>
    [Parameter]
    public LogoDefinition? Logo { get; set; }

    /// <summary>The host mode; generation controls show only in Open mode.</summary>
    [Parameter]
    public ConfigForgeMode Mode { get; set; }

    /// <summary>Whether the generate-document button is shown (Open mode only). Default true.</summary>
    [Parameter]
    public bool ShowGenerateButton { get; set; } = true;

    /// <summary>Custom host-supplied links rendered before the built-in header buttons.</summary>
    [Parameter]
    public IReadOnlyList<ConfigForgeHeaderAction> HeaderActions { get; set; } = [];

    /// <summary>Raised when the user clicks the generate-document button.</summary>
    [Parameter]
    public EventCallback OnGenerate { get; set; }

    /// <summary>Whether the code-panel toggle button is shown (left of generate).</summary>
    [Parameter]
    public bool ShowCodePanel { get; set; }

    /// <summary>Whether the code panel is currently open (drives the button label).</summary>
    [Parameter]
    public bool CodePanelOpen { get; set; }

    /// <summary>Raised when the user toggles the code panel.</summary>
    [Parameter]
    public EventCallback OnToggleCodePanel { get; set; }

    private bool IsHeaderPosition(LogoPosition position) => Logo is not null && Logo.Position == position;
}
