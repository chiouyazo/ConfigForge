@implements IDisposable

<ThemeProvider Theme="Theme">
    <div class="cf-shell">
        <AppHeader Title="@HeaderTitle"
                   Subtitle="@HeaderSubtitle"
                   Logo="Theme.Logo"
                   Mode="Mode"
                   ShowGenerateButton="ShowGenerateButton"
                   ShowCodePanel="ShowCodePanel"
                   CodePanelOpen="_codePanelOpen"
                   OnToggleCodePanel="ToggleCodePanel"
                   OnGenerate="ShowGenerateDialog" />

        <div class="cf-body">
            <aside class="cf-sidebar">
                <SidebarNav Categories="Categories"
                            ActiveIndex="Session.ActiveCategoryIndex"
                            Logo="Theme.Logo"
                            OnSelect="OnSelectCategory" />
            </aside>

            <main class="cf-main">
                <ValidationSummary ParseResult="Session.ParseResult" />
                <ConfigCanvas />
                <ActionButtonBar />
            </main>

            @if (ShowCodePanel && _codePanelOpen)
            {
                <aside class="cf-codepanel">
                    <div class="cf-codepanel-head">
                        <div class="cf-codepanel-tabs">
                            <button type="button"
                                    class="cf-codepanel-tab @(_codeView == CodeView.Config ? "cf-active" : string.Empty)"
                                    @onclick="@(() => SetCodeView(CodeView.Config))">
                                Config JSON
                            </button>
                            @if (HasSchemaJson)
                            {
                                <button type="button"
                                        class="cf-codepanel-tab @(_codeView == CodeView.Schema ? "cf-active" : string.Empty)"
                                        @onclick="@(() => SetCodeView(CodeView.Schema))">
                                    Schema
                                </button>
                            }
                        </div>
                        <button type="button" class="cf-button cf-button-secondary" @onclick="CopyCodeAsync">
                            @(_copied ? "Copied" : "Copy")
                        </button>
                    </div>
                    <pre class="cf-codepanel-code"><code>@CurrentCode</code></pre>
                </aside>
            }
        </div>

        @if (OnSave.HasDelegate)
        {
            <SaveDiscardBar HasChanges="Session.IsDirty"
                            IsValid="IsValid"
                            OnSave="SaveAsync"
                            OnDiscard="Discard" />
        }

        <ToastContainer />

        <GenerateDocumentDialog Visible="_showGenerateDialog"
                                Schema="Session.Schema"
                                HasUnsavedChanges="Session.IsDirty"
                                OnConfirm="OnGenerateConfirmedAsync"
                                OnCancel="HideGenerateDialog" />
    </div>
</ThemeProvider>
