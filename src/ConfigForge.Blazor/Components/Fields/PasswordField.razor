@inherits FieldComponentBase

<div class="cf-field">
    <FieldLabel Control="Control" />
    <div class="cf-input-group">
        <input class="cf-input"
               type="@(_revealed ? "text" : "password")"
               value="@CurrentString"
               placeholder="@Control.Placeholder"
               disabled="@(Disabled || Control.ReadOnly)"
               @onchange="OnInputAsync" />
        <button type="button"
                class="cf-icon-button"
                disabled="@(Disabled || Control.ReadOnly)"
                @onclick="ToggleReveal"
                aria-label="@(_revealed ? "Hide value" : "Show value")">
            @(_revealed ? "Hide" : "Show")
        </button>
    </div>
    <FieldDescription Control="Control" />
</div>

@code {
    private bool _revealed;

    private void ToggleReveal() => _revealed = !_revealed;

    private Task OnInputAsync(ChangeEventArgs e) =>
        NotifyChangedAsync(e.Value as string ?? string.Empty);
}
