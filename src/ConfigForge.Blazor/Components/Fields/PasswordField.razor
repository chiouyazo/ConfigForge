@inherits FieldComponentBase

<div class="cf-field">
    <FieldLabel Control="Control" />
    <div class="cf-input-group">
        <input class="cf-input"
               type="@(_revealed ? "text" : "password")"
               value="@CurrentString"
               placeholder="@Control.Placeholder"
               disabled="@(Disabled || Control.ReadOnly)"
               @onchange="OnInputAsync" />
        <button type="button"
                class="cf-icon-button"
                disabled="@(Disabled || Control.ReadOnly)"
                @onclick="ToggleReveal"
                aria-label="@(_revealed ? "Hide value" : "Show value")">
            @(_revealed ? "Hide" : "Show")
        </button>
    </div>
    @if (CurrentString.Length > 0)
    {
        <div class="cf-strength cf-strength-@_strengthClass">
            <span class="cf-strength-bar"></span>
            <span class="cf-strength-label">@_strengthLabel</span>
        </div>
    }
    <FieldDescription Control="Control" />
</div>

@code {
    private bool _revealed;

    private string _strengthClass = "weak";
    private string _strengthLabel = "Weak";

    private void ToggleReveal() => _revealed = !_revealed;

    private Task OnInputAsync(ChangeEventArgs e)
    {
        string value = e.Value as string ?? string.Empty;
        UpdateStrength(value);
        return NotifyChangedAsync(value);
    }

    private void UpdateStrength(string value)
    {
        int score = 0;
        if (value.Length >= 8)
        {
            score++;
        }

        if (value.Any(char.IsDigit))
        {
            score++;
        }

        if (value.Any(char.IsUpper) && value.Any(char.IsLower))
        {
            score++;
        }

        if (value.Any(c => !char.IsLetterOrDigit(c)))
        {
            score++;
        }

        (_strengthClass, _strengthLabel) = score switch
        {
            >= 4 => ("strong", "Strong"),
            >= 2 => ("medium", "Medium"),
            _ => ("weak", "Weak"),
        };
    }
}
