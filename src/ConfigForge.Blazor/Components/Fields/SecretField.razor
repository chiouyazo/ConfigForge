@inherits FieldComponentBase
@using ConfigForge.Abstractions

<div class="cf-field">
    <FieldLabel Control="Control" />

    @if (_editing)
    {
        <div class="cf-input-group">
            <input class="cf-input cf-secret-input"
                   type="@(_reveal ? "text" : "password")"
                   value="@_draft"
                   placeholder="@Control.Placeholder"
                   disabled="@(Disabled || Control.ReadOnly)"
                   autocomplete="new-password"
                   @oninput="OnInput"
                   @onchange="OnCommitAsync" />
            <button type="button" class="cf-icon-button" @onclick="ToggleReveal"
                    aria-label="@(_reveal ? "Hide value" : "Show value")">
                @(_reveal ? "Hide" : "Show")
            </button>
            <button type="button" class="cf-button cf-button-secondary" @onclick="DoneAsync">Done</button>
            <button type="button" class="cf-button" @onclick="CancelAsync">Cancel</button>
        </div>
    }
    else if (IsStored)
    {
        <div class="cf-secret">
            <span class="cf-secret-state">•••••••• stored</span>
            @if (Editable)
            {
                <button type="button" class="cf-button cf-button-secondary" @onclick="BeginEdit">Change</button>
                <button type="button" class="cf-button cf-button-danger" @onclick="ClearAsync">Clear</button>
            }
        </div>
    }
    else if (HasNewValue)
    {
        <div class="cf-secret">
            <span class="cf-secret-state cf-secret-new">new value entered</span>
            @if (Editable)
            {
                <button type="button" class="cf-button cf-button-secondary" @onclick="BeginEdit">Change</button>
                <button type="button" class="cf-button cf-button-danger" @onclick="ClearAsync">Clear</button>
            }
        </div>
    }
    else
    {
        <div class="cf-secret">
            <span class="cf-secret-state cf-secret-none">not set</span>
            @if (Editable)
            {
                <button type="button" class="cf-button cf-button-secondary" @onclick="BeginEdit">Set secret</button>
            }
        </div>
    }

    <FieldDescription Control="Control" />
</div>

@code {
    private bool _editing;
    private bool _reveal;
    private string _draft = string.Empty;
    private object? _original;

    private bool Editable => !(Disabled || Control.ReadOnly);

    private bool IsStored =>
        string.Equals(CurrentString, ConfigForgeSecret.StoredMarker, StringComparison.Ordinal);

    private bool HasNewValue => CurrentString.Length > 0 && !IsStored;

    private void BeginEdit()
    {
        _original = CurrentValue;
        _editing = true;
        _reveal = false;
        _draft = HasNewValue ? CurrentString : string.Empty;
    }

    private void ToggleReveal() => _reveal = !_reveal;

    private void OnInput(ChangeEventArgs e) => _draft = e.Value as string ?? string.Empty;

    private Task OnCommitAsync(ChangeEventArgs e)
    {
        _draft = e.Value as string ?? string.Empty;
        return NotifyChangedAsync(_draft.Length == 0 ? null : _draft);
    }

    private async Task DoneAsync()
    {
        await NotifyChangedAsync(_draft.Length == 0 ? null : _draft);
        _editing = false;
    }

    private async Task CancelAsync()
    {
        _editing = false;
        _draft = string.Empty;
        // Undo anything an on-blur commit wrote when the Cancel button was clicked.
        await NotifyChangedAsync(_original);
    }

    private Task ClearAsync()
    {
        _editing = false;
        return NotifyChangedAsync(null);
    }
}
