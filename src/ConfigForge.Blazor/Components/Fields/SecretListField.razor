@inherits FieldComponentBase
@using ConfigForge.Abstractions
@using Microsoft.AspNetCore.Components.Web

<div class="cf-field">
    <FieldLabel Control="Control" />

    <ul class="cf-secret-list">
        @for (int i = 0; i < _entries.Count; i++)
        {
            int index = i;
            bool stored = ConfigForgeSecret.IsStoredMarker(_entries[index]);
            <li class="cf-secret-list-item">
                <span class="cf-secret-state @(stored ? string.Empty : "cf-secret-new")">
                    @(stored ? "•••••••• stored" : "new value entered")
                </span>
                @if (Editable)
                {
                    <button type="button" class="cf-button cf-button-danger"
                            @onclick="@(() => RemoveAsync(index))">Remove</button>
                }
            </li>
        }
        @if (_entries.Count == 0)
        {
            <li class="cf-secret-state cf-secret-none">no secrets set</li>
        }
    </ul>

    @if (Editable)
    {
        <div class="cf-input-group">
            <input class="cf-input cf-secret-input"
                   type="@(_reveal ? "text" : "password")"
                   value="@_draft"
                   placeholder="@AddPlaceholder"
                   autocomplete="new-password"
                   @oninput="OnInput"
                   @onkeydown="OnKeyDownAsync" />
            <button type="button" class="cf-icon-button" @onclick="ToggleReveal"
                    aria-label="@(_reveal ? "Hide value" : "Show value")">
                @(_reveal ? "Hide" : "Show")
            </button>
            <button type="button" class="cf-button cf-button-secondary" @onclick="AddAsync">Add</button>
        </div>
    }

    <FieldDescription Control="Control" />
</div>

@code {
    private List<string> _entries = [];
    private string _draft = string.Empty;
    private bool _reveal;

    private bool Editable => !(Disabled || Control.ReadOnly);

    private string AddPlaceholder =>
        string.IsNullOrEmpty(Control.Placeholder)
            ? "Add a secret and press Enter"
            : Control.Placeholder;

    protected override void OnParametersSet() => _entries = ReadEntries();

    private void ToggleReveal() => _reveal = !_reveal;

    private void OnInput(ChangeEventArgs e) => _draft = e.Value as string ?? string.Empty;

    private Task OnKeyDownAsync(KeyboardEventArgs e) =>
        e.Key == "Enter" ? AddAsync() : Task.CompletedTask;

    private Task AddAsync()
    {
        string value = _draft.Trim();
        _draft = string.Empty;
        _reveal = false;
        if (value.Length == 0)
        {
            return Task.CompletedTask;
        }

        // Append the new plaintext; the host encrypts it on save. Stored entries keep their
        // indexed markers, so kept and new elements stay correctly identified.
        _entries.Add(value);
        return NotifyChangedAsync(_entries.ToArray());
    }

    private Task RemoveAsync(int index)
    {
        _entries.RemoveAt(index);
        return NotifyChangedAsync(_entries.ToArray());
    }

    private List<string> ReadEntries()
    {
        List<string> result = [];
        if (CurrentValue is IEnumerable<object?> items)
        {
            foreach (object? item in items)
            {
                if (item is not null)
                {
                    result.Add(item.ToString() ?? string.Empty);
                }
            }
        }

        return result;
    }
}
