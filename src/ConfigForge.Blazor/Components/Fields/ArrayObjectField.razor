@using ConfigForge.Abstractions
@using ConfigForge.Core.Schema

<div class="cf-field cf-arrayobject">
    <FieldLabel Control="Header" />
    <FieldDescription Control="Header" />

    @{
        List<object?> items = ReadItems();
    }

    @if (items.Count == 0)
    {
        <p class="cf-arrayobject-empty">No entries yet.</p>
    }

    @for (int i = 0; i < items.Count; i++)
    {
        int index = i;
        <div class="cf-arrayobject-row">
            <div class="cf-arrayobject-row-body">
                @foreach (FieldDefinition child in Field.Children)
                {
                    <FieldRenderer Field="RebaseChild(child, index)" Disabled="Disabled" />
                }
            </div>
            @if (!Disabled)
            {
                <button type="button"
                        class="cf-button cf-button-danger cf-arrayobject-remove"
                        @onclick="@(() => RemoveAt(index))">
                    Remove
                </button>
            }
        </div>
    }

    @if (!Disabled)
    {
        <button type="button" class="cf-button cf-arrayobject-add" @onclick="AddItem">
            @AddLabel
        </button>
    }
</div>

@code {
    /// <summary>The array-of-objects field definition, carrying the item templates.</summary>
    [Parameter]
    [EditorRequired]
    public FieldDefinition Field { get; set; } = new();

    /// <summary>True when the control must not be edited.</summary>
    [Parameter]
    public bool Disabled { get; set; }

    [Inject]
    private EditingSession Session { get; set; } = default!;

    private ControlDescriptor Header =>
        new()
        {
            Key = Field.Key,
            ControlType = Field.ControlType,
            Title = Field.Title,
            Description = Field.Description,
            Tooltip = Field.Tooltip,
            Required = Field.Required,
        };

    private string AddLabel => string.IsNullOrEmpty(Field.Title) ? "Add" : $"Add {Field.Title}";

    private FieldDefinition RebaseChild(FieldDefinition child, int index) =>
        child.WithKey($"{Field.Key}/{index}/{child.Key}");

    private List<object?> ReadItems() =>
        Session.Document[Field.Key] switch
        {
            List<object?> list => list,
            IEnumerable<object?> sequence => [.. sequence],
            _ => [],
        };

    private void AddItem()
    {
        List<object?> items = [.. ReadItems(), new Dictionary<string, object?>(StringComparer.Ordinal)];
        Session.SetFieldValue(Field.Key, items);
    }

    private void RemoveAt(int index)
    {
        List<object?> items = ReadItems();
        if (index < 0 || index >= items.Count)
        {
            return;
        }

        items.RemoveAt(index);
        Session.SetFieldValue(Field.Key, items);
    }
}
