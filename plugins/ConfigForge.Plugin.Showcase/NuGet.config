<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Self-contained restore configuration for the external plugin. The "local"
    feed points at the repo's built artifacts so ConfigForge.Abstractions 0.1.0
    resolves as a published package (not a project reference). nuget.org provides
    everything else.
  -->
  <packageSources>
    <clear />
    <add key="local" value="../../artifacts" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
